{
	"$schema": "https://github.com/Skiley/runfile/releases/latest/download/v0.schema.json",
	"globals": {
		"env": {
			"CARGO_TARGET_DIR": "target-{{ RUN.os }}"
		},
		"logging": true
	},
	"includes": [
		{
			"namespace": "wsl",
			"path": "Runfile-wsl.json"
		}
	],
	"targets": {
		"build": {
			"description": "Build all crates in debug mode",
			"commands": [
				"cargo build {{ ARGS }}",
				{
					"if": "{{ RUN.os == 'windows' }}",
					"then": "@wsl:build"
				},
				"@install"
			]
		},
		"build:release": {
			"description": "Build all crates in release mode",
			"commands": [
				"cargo build --release {{ ARGS }}",
				{
					"if": "{{ RUN.os == 'windows' }}",
					"then": "@wsl:build:release"
				}
			]
		},
		"clean": {
			"description": "Remove build artifacts",
			"commands": [
				{
					"for": "dir",
					"in": [
						"",
						"-linux",
						"-mac",
						"-windows"
					],
					"do": "cargo clean --target-dir target{{ VARS.dir }}"
				}
			]
		},
		"install": {
			"description": "Copies the built binary to .local/bin as \"j18nd\"",
			"commands": [
				{
					"if": "{{ RUN.os == 'windows' }}",
					"then": [
						"{{ define(executable, 'j18n.exe') }}",
						"{{ define(installed, 'j18nd.exe') }}"
					],
					"else": [
						"{{ define(executable, 'j18n') }}",
						"{{ define(installed, 'j18nd') }}"
					]
				},
				"cp {{ ENV.CARGO_TARGET_DIR }}/debug/{{ VARS.executable }} ~/.local/bin/{{ VARS.installed }}"
			],
			"detach": true,
			"forceShell": "sh",
			"parallel": true
		},
		"lint": {
			"description": "Completely lints (type-checks, formats, runs Clippy) the project",
			"commands": [
				"cargo check",
				"cargo fmt --all",
				"cargo clippy --all-targets --all-features -- -D warnings",
				{
					"if": "{{ RUN.os == 'windows' }}",
					"then": "@wsl:lint"
				}
			]
		},
		"release": {
			"description": "Bumps the workspace version (major/minor/patch) in Cargo.toml, refreshes Cargo.lock, tags the commit, then pushes everything so CI runs the release",
			"commands": [
				"{{ define(part, one_of(ARGS, 'major', 'minor', 'patch')) }}",
				"{{ define(cargo, read_file('Cargo.toml')) }}",
				"{{ define(cur, regex_capture(VARS.cargo, '(?m)^version = \"([^\"]+)\"', '1')) }}",
				{
					"match": "{{ VARS.part }}",
					"cases": {
						"major": "{{ define(new, concat(add(nth(VARS.cur, '.', '0'), '1'), '.0.0')) }}",
						"minor": "{{ define(new, concat(nth(VARS.cur, '.', '0'), '.', add(nth(VARS.cur, '.', '1'), '1'), '.0')) }}",
						"patch": "{{ define(new, concat(nth(VARS.cur, '.', '0'), '.', nth(VARS.cur, '.', '1'), '.', add(nth(VARS.cur, '.', '2'), '1'))) }}"
					}
				},
				"{{ define(updated, regex_replace(VARS.cargo, '(?m)^version = \"[^\"]+\"', concat('version = \"', VARS.new, '\"'))) }}",
				"{{ write_file('Cargo.toml', VARS.updated) }}",
				"cargo update --workspace",
				"echo 'Bumped: version {{ VARS.cur }} -> {{ VARS.new }}'",
				"git commit Cargo.toml Cargo.lock -m {{ shell_quote(concat('bump to ', VARS.new)) }}",
				"{{ define(tag, concat('v', VARS.new)) }}",
				"echo Tagging {{ VARS.tag }}",
				"git tag {{ shell_quote(VARS.tag) }}",
				"git push",
				"git push --tags"
			],
			"forceShell": "sh"
		},
		"test": {
			"description": "Run all workspace tests",
			"commands": [
				"cargo test {{ ARGS }}",
				{
					"if": "{{ RUN.os == 'windows' }}",
					"then": "@wsl:test"
				}
			]
		}
	}
}
